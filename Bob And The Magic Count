import math
from functools import reduce

def gcd(a, b):
    return math.gcd(a, b)

def solve():
    try:
        line1 = input().split()
        if not line1: return
        n = int(line1[0])
        a = list(map(int, input().split()))
    except EOFError:
        return

    current_gcd = reduce(gcd, a)
    
    if current_gcd == 1:
        print(0)
        return

    
    if gcd(current_gcd, n) == 1:
        print(1)
    else:
        
        print(2)


t = int(input())
for _ in range(t):
    solve()
