from collections import deque

def solve():
    
    import sys
    input_data = sys.stdin.read().split()
    if not input_data:
        return
    
    N, M, K, S = map(int, input_data[:4])
    adj = [[] for _ in range(N + 1)]
    
   
    idx = 4
    for _ in range(M):
        u = int(input_data[idx])
        v = int(input_data[idx+1])
        adj[u].append(v)
        adj[v].append(u)
        idx += 2
        
    
    visited = {S}
    queue = deque([(S, 0)]) # (current_city, distance_from_start)
    reachable_count = 0
    
    while queue:
        curr_city, dist = queue.popleft()
        
        
        if dist <= K:
            reachable_count += 1
            
           
            if dist < K:
                for neighbor in adj[curr_city]:
                    if neighbor not in visited:
                        visited.add(neighbor)
                        queue.append((neighbor, dist + 1))
                        
    print(reachable_count)

solve()
