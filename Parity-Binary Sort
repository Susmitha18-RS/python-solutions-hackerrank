def count_set_bits(n):
   
    return bin(n).count('1')

def solve():
    import sys
    input = sys.stdin.read().split()
    if not input:
        return
    
    T = int(input[0])
    idx = 1
    
    for _ in range(T):
        N = int(input[idx])
        idx += 1
        A = list(map(int, input[idx : idx + N]))
        idx += N
        
        A.sort(key=lambda x: (count_set_bits(x) % 2, x))
        
        print(*(A))

if __name__ == "__main__":
    solve()
