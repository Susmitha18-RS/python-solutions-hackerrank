import re
def is_valid_float():
    t = int(input())
    pattern = r'^[+-]?[0-9]*\.[0-9]+$'
    for _ in range(t):
        s = input().strip()
        if re.match(pattern, s):
            try:
                float(s)
                print(True)
            except ValueError:
                print(False)
        else:
            print(False)
if __name__ == "__main__":
    is_valid_float()

