maxdepth = 0

def depth(elem, level):
    global maxdepth
    # Increment level for the current element (starting from -1 for the root's call)
    level += 1
    # Update maxdepth if the current level is deeper than the recorded maximum
    if level > maxdepth:
        maxdepth = level
    # Recursively call the depth function for all children
    for child in elem:
        depth(child, level)


